# Base URL of the backend API consumed by dataProvider and authProvider.
# Defaults to http://localhost:3002 if not set.
VITE_API_URL=http://localhost:3002

# Free API key for the Ticketmaster Discovery API, used by the "Découvrir"
# page to show real-world events. Get one at https://developer.ticketmaster.com/
VITE_TICKETMASTER_API_KEY=

